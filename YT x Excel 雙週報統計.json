      "parameters": {
        "jsCode": "// 1. 從先前的 'Code in JavaScript' 節點獲取使用者要求的開始與結束日期\n// 這裡使用 .first() 確保拿到最初定義的區間\nconst startStr = $('分類整理').first().json.start; \nconst endStr = $('分類整理').first().json.end;\n\n// 2. 將字串轉換為 Date 物件以便比較\nconst startDate = new Date(startStr);\nconst endDate = new Date(endStr);\n\n// 3. 篩選輸入的資料項 (items)\nreturn items.filter(item => {\n  const dateStr = item.json[\"日期\"];\n  \n  // 如果日期欄位為空，則跳過該筆資料\n  if (!dateStr || dateStr.trim() === \"\") return false;\n  \n  const itemDate = new Date(dateStr);\n  \n  // 判斷日期是否在區間以內 (包含起點與終點)\n  return itemDate >= startDate && itemDate <= endDate;\n});"
      },
