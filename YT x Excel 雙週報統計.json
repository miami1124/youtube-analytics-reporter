    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const url = item.json[\"網址\"];\n  let videoId = null;\n\n  if (typeof url === 'string') {\n    const match = url.match(\n      /(?:youtube\\.com\\/(?:watch\\?v=|shorts\\/)|youtu\\.be\\/)([A-Za-z0-9_-]{11})/\n    );\n    videoId = match ? match[1] : null;\n  }\n\n  return {\n    json: {\n      ...item.json,\n      videoId,\n    }\n  };\n});\n\n"
      },
